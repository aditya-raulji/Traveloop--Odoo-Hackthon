// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH MODELS (NextAuth.js required)
// ============================================

model User {
  id                 String    @id @default(cuid())
  username           String    @unique
  firstName          String
  lastName           String
  email              String    @unique
  emailVerified      DateTime?
  password           String?
  phone              String?
  city               String?
  country            String?
  additionalInfo     String?
  profileImage       String?
  language           String    @default("en")
  isAdmin            Boolean   @default(false)
  invoiceStatus      String    @default("pending")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  accounts           Account[]
  sessions           Session[]
  trips              Trip[]
  communityPosts     CommunityPost[]
  communityLikes     CommunityLike[]
  adminLogs          AdminLog[]

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// CITY & ACTIVITY (Master Data)
// ============================================

model City {
  id          String   @id @default(cuid())
  name        String
  country     String
  countryFlag String?
  region      String   // Asia, Europe, Americas, Africa, Middle East, Oceania
  costIndex   Int      @default(3) // 1=budget to 5=expensive
  popularity  Int      @default(0) // higher = more popular
  imageUrl    String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  activities  Activity[]
  stops       Stop[]

  @@map("cities")
}

model Activity {
  id             String   @id @default(cuid())
  name           String
  description    String?  @db.Text
  cityId         String
  type           ActivityType @default(SIGHTSEEING)
  estimatedCost  Float    @default(0)
  duration       String?  // e.g., "2 hours", "Full Day"
  durationHours  Float?   // numeric for filtering
  imageUrl       String?
  images         String[] // multiple images array
  popularity     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  city           City           @relation(fields: [cityId], references: [id], onDelete: Cascade)
  stopActivities StopActivity[]

  @@map("activities")
}

enum ActivityType {
  SIGHTSEEING
  FOOD_DINING
  ADVENTURE
  CULTURE
  SHOPPING
  NIGHTLIFE
  NATURE
  WELLNESS
  FAMILY
  SPORTS
  OTHER
}

// ============================================
// TRIP & ITINERARY
// ============================================

model Trip {
  id                   String    @id @default(cuid())
  userId               String
  name                 String
  description          String?   @db.Text
  startDate            DateTime?
  endDate              DateTime?
  coverImage           String?
  isPublic             Boolean   @default(false)
  shareToken           String    @unique @default(cuid())
  checklistShareToken  String    @unique @default(cuid())
  invoiceStatus        String    @default("pending") // "pending" | "paid"
  taxPercent           Float     @default(18.0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops          Stop[]
  sections       Section[]
  budget         Budget?
  packingItems   PackingItem[]
  tripNotes      TripNote[]
  communityPosts CommunityPost[]

  @@map("trips")
}

// Stop = a city added to the trip (used in itinerary builder)
model Stop {
  id         String    @id @default(cuid())
  tripId     String
  cityId     String
  order      Int       @default(0)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  trip           Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city           City           @relation(fields: [cityId], references: [id])
  stopActivities StopActivity[]
  tripNotes      TripNote[]

  @@map("stops")
}

// Activity assigned to a stop
model StopActivity {
  id            String    @id @default(cuid())
  stopId        String
  activityId    String
  scheduledTime String?   // e.g., "10:00 AM"
  scheduledDate DateTime?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())

  // Relations
  stop     Stop     @relation(fields: [stopId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id])

  @@unique([stopId, activityId])
  @@map("stop_activities")
}

// Section = flexible itinerary block (hotel, transport, activity, etc.)
// Used in the "Build Itinerary" screen (Screen 5)
model Section {
  id            String      @id @default(cuid())
  tripId        String
  order         Int         @default(0)
  title         String?
  description   String?     @db.Text
  sectionType   SectionType @default(GENERAL)
  startDate     DateTime?
  endDate       DateTime?
  isPlanned     Boolean     @default(false)
  attachmentUrl String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  trip          Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sectionBudgets SectionBudget[]

  @@map("sections")
}

enum SectionType {
  TRAVEL
  HOTEL
  FOOD
  ACTIVITY
  GENERAL
}

// Budget per section (e.g., Hotel: ₹5000, Transport: ₹2000)
model SectionBudget {
  id             String   @id @default(cuid())
  sectionId      String
  category       BudgetCategory @default(MISCELLANEOUS)
  amount         Float    @default(0)
  description    String?
  billingDetails String? // e.g., "4 nights", "1 ticket"
  unitCost       Float?
  quantity       Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("section_budgets")
}

enum BudgetCategory {
  TRANSPORT
  HOTEL
  ACTIVITY
  FOOD
  STAY
  MISCELLANEOUS
}

// Overall trip budget (planned limits per category)
model Budget {
  id              String   @id @default(cuid())
  tripId          String   @unique
  transport       Float    @default(0)
  accommodation   Float    @default(0)
  activities      Float    @default(0)
  meals           Float    @default(0)
  miscellaneous   Float    @default(0)
  totalBudget     Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("budgets")
}

// ============================================
// PACKING CHECKLIST
// ============================================

model PackingItem {
  id        String          @id @default(cuid())
  tripId    String
  name      String
  category  PackingCategory @default(OTHER)
  isPacked  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Relations
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("packing_items")
}

enum PackingCategory {
  CLOTHING
  DOCUMENTS
  ELECTRONICS
  TOILETRIES
  MEDICINE
  SNACKS
  ACCESSORIES
  OTHER
}

// ============================================
// TRIP NOTES / JOURNAL
// ============================================

model TripNote {
  id          String    @id @default(cuid())
  tripId      String
  stopId      String?
  title       String?
  content     String    @db.Text
  linkedDay   Int?      // Day number within trip (1, 2, 3...)
  isImportant Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  trip Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stop Stop? @relation(fields: [stopId], references: [id], onDelete: SetNull)

  @@map("trip_notes")
}

// ============================================
// COMMUNITY
// ============================================

model CommunityPost {
  id          String   @id @default(cuid())
  userId      String
  tripId      String?
  content     String   @db.Text
  images      String[] // array of Cloudinary URLs
  likesCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip   Trip?           @relation(fields: [tripId], references: [id], onDelete: SetNull)
  likes  CommunityLike[]

  @@map("community_posts")
}

model CommunityLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  // Relations
  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId]) // one like per user per post
  @@map("community_likes")
}

// ============================================
// ADMIN
// ============================================

model AdminLog {
  id        String   @id @default(cuid())
  action    String   // e.g., "USER_SIGNUP", "TRIP_DELETED", "USER_DELETED"
  userId    String?
  targetId  String?  // id of the affected resource
  metadata  Json?    // any extra info as JSON
  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("admin_logs")
}